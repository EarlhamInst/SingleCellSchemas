{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Extract All Components in All Standards",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/convert.py",
      "console": "integratedTerminal",
      "args": [],
      "python": "${workspaceFolder}/venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true, // Skip debugging code from libraries
      "pythonArgs": [
        "-Xfrozen_modules=off" // Disable frozen modules to ensure breakpoints are hit
      ]
    },
    {
      "name": "Python: Extract Extract Single-cell components for Darwin Core standard",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/convert.py",
      "console": "integratedTerminal",
      "args": [
        "single_cell dwc" // Schema type argument (either 'single_cell' or 'images'); Termset argument (either 'dwc', 'mixs' or 'tol')
      ],
      "python": "${workspaceFolder}/venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": true, // Skip debugging code from libraries
      "pythonArgs": [
        "-Xfrozen_modules=off" // Disable frozen modules to ensure breakpoints are hit
      ]
    },
    {
      "name": "Python: Extract Single-cell components in HTML format",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/convert.py",
      "console": "integratedTerminal",
      "args": [
        "single_cell html" // Schema type argument (either 'single_cell' or 'images'); Output format argument (either 'xlsx', 'json', 'xml')
      ],
      "python": "${workspaceFolder}/venv/bin/python",
